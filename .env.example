# Ticketmaster MVP — environment configuration
# Copy to .env and uncomment values you need to override.

# Server
# HOST=0.0.0.0
# PORT=8000
# LOG_LEVEL=info

# Compose host port (maps to container port 8000)
# APP_PORT=8010

# Database (PostgreSQL 16 via asyncpg)
# DATABASE_URL=postgresql+asyncpg://ticketmaster:ticketmaster@localhost:5432/ticketmaster

# Redis (seat lock fencing)
# REDIS_URL=redis://localhost:6379/0

# Seat hold TTL in seconds (default: 600 = 10 minutes)
# SEAT_HOLD_TTL=600
