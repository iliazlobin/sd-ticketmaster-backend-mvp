# Ticketmaster — e2e-verify manifest (sourced by `set -a; . manifest.env`)
# Every multi-word value MUST be single-quoted or it executes at source time.

MODE=docker
PORT=8010

# Test-mode env: SEED_DEMO_DATA=1 makes the black-box suite find events (no event-creation
# API exists); SEAT_HOLD_TTL=5 lets FR-7 (expired-hold release) verify within its 15s poll.
# Both flow into docker-compose.yml's ${...} defaults; production sets neither.
UP='SEED_DEMO_DATA=1 SEAT_HOLD_TTL=5 docker compose up -d --build'
DOWN='docker compose down -v'
READY='curl -sf http://localhost:$PORT/healthz'
LOGS='docker compose logs --tail=50'
ACCEPTANCE='PYTHONPATH= API_BASE_URL="http://localhost:$PORT" "$PY" -m pytest verify/acceptance -q'
TEST_DEPS='httpx pytest'
